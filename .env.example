# Database
DATABASE_URL="postgresql://user:password@localhost:5432/fitness_finder"

# Redis (optional - falls back to in-memory)
REDIS_URL="redis://localhost:6379"

# Session Secret (required - generates random if not set)
SESSION_SECRET="your-secure-session-secret"

# Google Maps API (optional - shows placeholder if not set)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY="your_google_maps_api_key"

# App URL (required for production)
NEXT_PUBLIC_BASE_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# CORS - comma-separated origins
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:3001"

# Node environment
NODE_ENV="development"

# ═══════════════════════════════════════════════════════════════════════════
# EMAIL CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════
# Provider options: "console" (dev), "resend", "sendgrid", "smtp"
EMAIL_PROVIDER="console"
EMAIL_FROM="noreply@findmyfitness.com"
EMAIL_FROM_NAME="Find My Fitness"

# Resend (recommended - easy to set up, free tier available)
# Sign up at https://resend.com
RESEND_API_KEY="re_xxxxxxxx"

# SendGrid (alternative)
# SENDGRID_API_KEY="SG.xxxxxxxx"

# SMTP (Gmail, Outlook, etc.)
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT="587"
# SMTP_USER="your@gmail.com"
# SMTP_PASS="your-app-password"
